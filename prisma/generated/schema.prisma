generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id
  name        String
  phone       String      @unique
  email       String?     @unique
  role        UserRole
  accountType AccountType
  status      UserStatus  @default(ACTIVE)
  createdAt   DateTime
  updatedAt   DateTime

  teacherProfile  Teacher?
  customerProfile Customer?

  @@map("users")
}

enum UserRole {
  MANAGER
  COMMON
}

enum AccountType {
  TEACHER
  CUSTOMER
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum SharedStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id     String @id
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@map("customers")
}

model Teacher {
  id          String       @id
  avatar      String
  biUrl       String?
  subjects    Subject[]
  weekDays    WeekDay[]
  zones       Zone[]
  gradeLevels GradeLevel[]

  status TeacherStatus @default(PENDING)

  pricingTierId String?
  priceTier     TeacherPricingTier? @relation(fields: [pricingTierId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@map("teachers")
}

enum TeacherStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model Subject {
  id       String       @id
  name     String
  status   SharedStatus @default(ACTIVE)
  teachers Teacher[]

  @@map("subjects")
}

model WeekDay {
  id       String       @id
  name     String
  status   SharedStatus @default(ACTIVE)
  teachers Teacher[]

  @@map("weekdays")
}

model GradeLevel {
  id       String       @id
  name     String
  status   SharedStatus @default(ACTIVE)
  teachers Teacher[]

  @@map("gradelevels")
}

model Zone {
  id       String       @id
  name     String
  status   SharedStatus @default(ACTIVE)
  teachers Teacher[]

  @@map("zones")
}

model TeacherPricingTier {
  id       String       @id
  value    String
  status   SharedStatus
  teachers Teacher[]

  @@map("teacher_pricing_tiers")
}
