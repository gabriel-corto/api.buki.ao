generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  email       String?  @unique
  role        String
  accountType String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
